{
	"name": "bot-trading",
	"private": true,
	"version": "0.1.0",
	"description": "AI-driven trading agent monorepo",
	"packageManager": "pnpm@9.12.1",
	"scripts": {
		"build": "pnpm -r --if-present build",
		"dev": "pnpm -r --parallel --if-present dev",
		"lint": "pnpm -r --if-present lint",
		"test": "pnpm -r --if-present test",
		"start:trading-api": "pnpm --filter @apps/trading-api dev",
		"start:telegram-bot": "pnpm --filter @apps/telegram-bot dev",
		"start:market-data": "pnpm --filter @services/market-data-service dev",
		"start:signal-engine": "pnpm --filter @services/signal-engine dev",
		"start:risk-engine": "pnpm --filter @services/risk-engine dev",
		"start:execution-engine": "pnpm --filter @services/execution-engine dev"
	}
}
